APP_ENV=development
ENV=dev
TZ=Europe/Istanbul
LOG_LEVEL=INFO

DEBUG=false
UVICORN_RELOAD=false

TEST_MODE=true
PAPER_TRADING=true
TELEGRAM_ENABLED=false

# =========================
# DATABASE
# =========================
DB_PATH=backend/trading_bot.db
RESEARCH_DB_PATH=backend/research.db

# =========================
# EXCHANGE
# =========================
EXCHANGE_ID=binance
QUOTE_ASSET=USDT

# =========================
# PAPER WALLET
# =========================
PAPER_USDT=1000
PAPER_BTC=0
PAPER_ETH=0

COMMISSION_RATE=0.001
PAPER_SLIPPAGE_BPS=2
PAPER_SLIPPAGE_JITTER_BPS=1

# =========================
# CAPITAL
# =========================
TOTAL_CAPITAL_USDT=1000

# =========================
# RISK MANAGEMENT
# =========================
RISK_PER_TRADE=0.01

BASE_RISK_PCT_SHORT=0.003
BASE_RISK_PCT_MEDIUM=0.0025
BASE_RISK_PCT_LONG=0.002

TOTAL_MAX_HEAT_PCT=0.015

SLEEVE_MAX_HEAT_SHORT=0.006
SLEEVE_MAX_HEAT_MEDIUM=0.005
SLEEVE_MAX_HEAT_LONG=0.004

MAX_OPEN_POSITIONS_TOTAL=6
MAX_OPEN_POSITIONS_PER_SLEEVE=1
POSITION_DUPLICATE_BLOCK=true

DAILY_LOSS_LIMIT_PCT=0.02
WEEKLY_LOSS_LIMIT_PCT=0.05

DAILY_MAX_LOSS_USDT=50

# =========================
# EXECUTION HEALTH
# =========================
EXECUTION_HEALTH_SCALING_ENABLED=true

MAX_SPREAD_BPS=12

MAX_SLIPPAGE_BPS_SHORT=10
MAX_SLIPPAGE_BPS_MEDIUM=14
MAX_SLIPPAGE_BPS_LONG=18

API_ERROR_COOLDOWN_SECONDS=180
HTTP_429_COOLDOWN_SECONDS=300

# =========================
# CORRELATION CONTROL
# =========================
CORR_KILL_ENABLED=true
CORR_LOOKBACK_BARS=96
CORR_KILL_THRESHOLD=0.85
CORR_CLUSTER_MAX_COUNT=2
CORR_FREEZE_MINUTES=30

# =========================
# REGIME FILTER
# =========================
REGIME_GUARD_ENABLED=true
REGIME_MODEL=rules_v1

REGIME_ALLOWED_SHORT=BULLISH,NEUTRAL_UP
REGIME_ALLOWED_MEDIUM=BULLISH,NEUTRAL_UP,RANGE
REGIME_ALLOWED_LONG=BULLISH,NEUTRAL_UP

# =========================
# SIGNAL AUDIT
# =========================
SIGNAL_AUDIT_ENABLED=true
AUDIT_RECENT_WINDOW_HOURS=24

# =========================
# MARKET UNIVERSE
# =========================
SHORT_UNIVERSE=SUI/USDT,NEAR/USDT,AVAX/USDT
MEDIUM_UNIVERSE=LINK/USDT,AAVE/USDT,RNDR/USDT
LONG_UNIVERSE=BTC/USDT,ETH/USDT

# =========================
# TIMEFRAMES
# =========================
SHORT_TIMEFRAME=5m
MEDIUM_TIMEFRAME=15m
LONG_TIMEFRAME=1h

SCAN_TIMEFRAME=15m

# =========================
# SNAPBACK STRATEGY
# =========================
SNAPBACK_PULLBACK_LOOKBACK=6
SNAPBACK_MIN_DROP_PCT=0.002
SNAPBACK_MIN_RECLAIM_PCT=0.0005

SNAPBACK_MIN_ATR_PCT=0.002
SNAPBACK_MAX_ATR_PCT=0.03

SNAPBACK_EMA_FAST_LEN=20
SNAPBACK_EMA_FAST_TOLERANCE_MULT=1.003

SNAPBACK_ATR_SL_MULT=1.2
SNAPBACK_ATR_TP_MULT=1.8

# =========================
# GRID STRATEGY
# =========================
BTC_GRID_LOWER=64000
BTC_GRID_UPPER=74000

ETH_GRID_LOWER=1800
ETH_GRID_UPPER=2200

GRID_COUNT=50
GRID_USE_FIXED_CAPITAL=true
GRID_CAPITAL_PER_LEVEL=15

GRID_MAX_POSITIONS_PER_SYMBOL=5
GRID_MAX_INVENTORY_USDT=500

GRID_WIDTH_PCT=0.04
GRID_EMERGENCY_STOP_PCT=0.03

GRID_TAKE_PROFIT_PCT=0.02
GRID_STOP_LOSS_PCT=0.03

GRID_MIN_PROFIT_PCT=0.001
GRID_MIN_PROFIT_TO_SELL=0.001

GRID_SELL_ONLY_PROFITABLE=true
GRID_AUTO_REBALANCE=false
GRID_FIFO_SELL=false

RE_ENTRY_COOLDOWN_SECONDS=300
RE_ENTRY_LOSS_COOLDOWN_MULT=2.0
RE_ENTRY_PREVENT_HIGHER_BUY=true
RE_ENTRY_MAX_PRICE_INCREASE_PCT=0.005

MIN_ATR_PCT=0.001
MAX_ATR_PCT=0.05
MIN_VOLUME_RATIO=0.3

# =========================
# BACKTEST
# =========================
BACKTEST_SYMBOL=BTC/USDT
BACKTEST_START=2025-12-01

# =========================
# API
# =========================
CORS_ORIGINS=["http://localhost:5173"]