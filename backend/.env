SLEEVE_MAX_HEAT_LONG=0.02

# ── AÇIK POZİSYON LİMİTLERİ ──────────────────────────────────
# Grid stratejisi aynı anda birden fazla seviyede pozisyon açar.
# MAX_OPEN_POSITIONS: toplam açık pozisyon sayısı (scanner engeli)
# GRID_MAX_POSITIONS_PER_SYMBOL: her coin için maksimum grid pozisyonu
MAX_OPEN_POSITIONS=20
MAX_OPEN_POSITIONS_TOTAL=20
MAX_OPEN_POSITIONS_PER_SLEEVE=10
POSITION_DUPLICATE_BLOCK=false
GRID_MAX_POSITIONS_PER_SYMBOL=10
MAX_DAILY_LOSS_PCT=0.03
MAX_DAILY_LOSS_USDT=30
# ── GÜNLÜK KAYIP LİMİTİ ──────────────────────────────────────
# Equity'nin %3'ü aşılırsa bot duraklar.
# DAILY_MAX_LOSS_USDT=0 → sadece yüzde bazlı limit aktif.
DAILY_LOSS_LIMIT_PCT=0.03
WEEKLY_LOSS_LIMIT_PCT=0.08
DAILY_MAX_LOSS_USDT=30
DAILY_MAX_LOSS_PCT=0.03

# =========================
# COOLDOWN (BEKLEMESÜRESİ)
# =========================
# ÖNEMLI: Bu global cooldown. Grid için 60 saniye yeterli.
# Her iki coin de aynı sayacı paylaştığından düşük tutulmalı.
COOLDOWN_SECONDS=60

# =========================
# EXECUTION HEALTH
# =========================
EXECUTION_HEALTH_SCALING_ENABLED=true
MAX_SPREAD_BPS=15
MAX_SLIPPAGE_BPS_SHORT=12
MAX_SLIPPAGE_BPS_MEDIUM=16
MAX_SLIPPAGE_BPS_LONG=20
API_ERROR_COOLDOWN_SECONDS=120
HTTP_429_COOLDOWN_SECONDS=180

# =========================
# KORELASYON KONTROLÜ
# =========================
# BTC/ETH yüksek korelasyonlu olduğundan eşiği yükselt,
# aksi hâlde her ETH sinyali bloklanır.
CORR_KILL_ENABLED=true
CORR_LOOKBACK_BARS=96
CORR_KILL_THRESHOLD=0.80
CORR_CLUSTER_MAX_COUNT=4
CORR_FREEZE_MINUTES=10
GRID_BTC_TREND_FILTER=true
GRID_BTC_TREND_ADX=45
GRID_BTC_TREND_ER=0.25
# =========================
# REJİM FİLTRESİ
# =========================
# Grid strateji için RANGE rejimine de izin ver.
# Yoksa yatay piyasada grid hiç açılmaz.
REGIME_GUARD_ENABLED=true
REGIME_MODEL=rules_v1

REGIME_ALLOWED_SHORT=BULLISH,NEUTRAL_UP
REGIME_ALLOWED_MEDIUM=BULLISH,NEUTRAL_UP,RANGE
REGIME_ALLOWED_LONG=BULLISH,NEUTRAL_UP,RANGE
GRID_FEE_BUFFER_PCT=0.002
GRID_ATR_TP_FACTOR=0.3
# =========================
