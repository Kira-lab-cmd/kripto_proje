MEDIUM_TIMEFRAME=15m
LONG_TIMEFRAME=1h
SCAN_TIMEFRAME=15m

# =========================
# SNAPBACK STRATEJİSİ
# =========================
# Snapback: grid sinyal vermediğinde devreye girer.
