AUDIT_RECENT_WINDOW_HOURS=24
BLOCKED_REPORT_TTL_S=120
TELEMETRY_INTERVAL_BLOCKED_SECONDS=30

# =========================
# PİYASA EVRENİ
# =========================
# V1 force universe: sadece bu iki coini tara.
